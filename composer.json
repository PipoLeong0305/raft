{
    "name": "pipo/raft",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Pipo\\Raft\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Pipo Leong",
            "email": "leongpipo0305@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "codeigniter4/devkit": "^1.2",
        "codeigniter4/framework": "^4.3"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "bin": [
        "bin/raft"
    ],
    "scripts": {
        "cs-fix": "php-cs-fixer fix --ansi --verbose --diff"
    }
}
